{
  "name": "fosshack",
  "version": "1.0.0",
  "description": "FOSSHACK Open Source Issues Platform — Data Layer",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/api/server.ts",
    "start": "ts-node src/api/server.ts",
    "workers": "ts-node src/queue/workers.ts",
    "seed": "ts-node scripts/run-seed.ts",
    "poller": "ts-node scripts/run-poller.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^1.10.2",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.29.1",
    "ioredis": "^5.3.0",
    "meilisearch": "^0.41.0",
    "node-cron": "^3.0.0",
    "openai": "^4.50.0",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/pg": "^8.11.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}

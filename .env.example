# GitHub — Personal Access Token with read scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# GitHub Webhook Secret — for real-time issue ingestion via webhooks
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Groq — LLM for issue semantic tagging and user profile extraction (llama-3.3-70b-versatile)
# Free tier at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# HuggingFace — Embeddings via BAAI/bge-large-en-v1.5 (1024 dims, open model)
# Free read token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_token_here

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgres://fosshack:fosshack@localhost:5433/fosshack

# Redis (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# Meilisearch (matches docker-compose.yml defaults)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=masterKey

# Server
PORT=3000
WORKER_CONCURRENCY=5
LOG_LEVEL=info
NODE_ENV=development
